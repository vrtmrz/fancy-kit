{
  "name": "@vrtmrz/obsidian-plugin-kit",
  "version": "0.1.1-rc.0",
  "description": "Reusable, testable primitives for Obsidian plugins",
  "type": "module",
  "license": "MIT",
  "author": "vorotamoroz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrtmrz/fancy-kit.git",
    "directory": "packages/obsidian-plugin-kit"
  },
  "homepage": "https://github.com/vrtmrz/fancy-kit/tree/main/packages/obsidian-plugin-kit#readme",
  "bugs": {
    "url": "https://github.com/vrtmrz/fancy-kit/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js"
    },
    "./notice": {
      "types": "./dist/notice.d.ts",
      "import": "./dist/notice.js"
    },
    "./progress": {
      "types": "./dist/progress.d.ts",
      "import": "./dist/progress.js"
    },
    "./ui": {
      "types": "./dist/ui-context.d.ts",
      "import": "./dist/ui-context.js"
    },
    "./vault": {
      "types": "./dist/vault.d.ts",
      "import": "./dist/vault.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "node ../../scripts/assert-bootstrap-publish.mjs && npm run check && npm run test && npm run build"
  },
  "dependencies": {
    "@vrtmrz/ui-interactions": "0.1.0"
  },
  "peerDependencies": {
    "obsidian": ">=1.8.7"
  }
}
