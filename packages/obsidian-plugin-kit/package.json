{
  "name": "@vrtmrz/obsidian-plugin-kit",
  "version": "0.0.0",
  "description": "Reusable, testable primitives for Obsidian plugins",
  "type": "module",
  "license": "MIT",
  "author": "vorotamoroz",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js"
    },
    "./notice": {
      "types": "./dist/notice.d.ts",
      "import": "./dist/notice.js"
    },
    "./progress": {
      "types": "./dist/progress.d.ts",
      "import": "./dist/progress.js"
    },
    "./ui": {
      "types": "./dist/ui-context.d.ts",
      "import": "./dist/ui-context.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run check && npm run test && npm run build"
  },
  "peerDependencies": {
    "obsidian": ">=1.8.7"
  }
}
