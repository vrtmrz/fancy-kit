{
  "name": "@vrtmrz/obsidian-test-session",
  "version": "0.2.1",
  "description": "Isolated real-Obsidian test session infrastructure for plug-in consumers",
  "type": "module",
  "license": "MIT",
  "author": "vorotamoroz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrtmrz/fancy-kit.git",
    "directory": "packages/obsidian-test-session"
  },
  "homepage": "https://github.com/vrtmrz/fancy-kit/tree/main/packages/obsidian-test-session#readme",
  "bugs": {
    "url": "https://github.com/vrtmrz/fancy-kit/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "updates.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "node ../../scripts/assert-bootstrap-publish.mjs && npm run check && npm run test && npm run build"
  },
  "peerDependencies": {
    "@types/node": ">=20",
    "playwright": ">=1.50.0"
  }
}
