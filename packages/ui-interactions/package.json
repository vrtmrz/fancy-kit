{
  "name": "@vrtmrz/ui-interactions",
  "version": "0.1.0-rc.0",
  "description": "Framework-neutral UI interaction contracts and test drivers",
  "type": "module",
  "license": "MIT",
  "author": "vorotamoroz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrtmrz/fancy-kit.git",
    "directory": "packages/ui-interactions"
  },
  "homepage": "https://github.com/vrtmrz/fancy-kit/tree/main/packages/ui-interactions#readme",
  "bugs": {
    "url": "https://github.com/vrtmrz/fancy-kit/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "node ../../scripts/assert-bootstrap-publish.mjs && npm run check && npm run test && npm run build"
  }
}
